<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#0f172a">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- Config Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1e293b"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️ 当前配置" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#64748b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagConfigInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#cbd5e1" android:lineSpacingExtra="4dp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Local DB Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1e293b"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💾 本地数据库" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#64748b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagDbInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#cbd5e1" android:lineSpacingExtra="4dp"
                android:fontFamily="monospace" />
        </LinearLayout>

        <!-- Tools Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1e293b"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:elevation="2dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔧 诊断工具" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#64748b" android:layout_marginBottom="12dp" />
            <Button android:id="@+id/btnTestConn" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="🌐 测试服务器连接"
                android:textAllCaps="false" android:textSize="14sp"
                android:backgroundTint="#4f46e5" android:textColor="#fff"
                android:layout_marginBottom="8dp" app:cornerRadius="8dp" />
            <Button android:id="@+id/btnTestUpload" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="⬆️ 测试上传GPS数据"
                android:textAllCaps="false" android:textSize="14sp"
                android:backgroundTint="#059669" android:textColor="#fff"
                android:layout_marginBottom="8dp" app:cornerRadius="8dp" />
            <Button android:id="@+id/btnIdentifyCar" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="🚗 重新识别车辆"
                android:textAllCaps="false" android:textSize="14sp"
                android:backgroundTint="#7c3aed" android:textColor="#fff"
                android:layout_marginBottom="8dp" app:cornerRadius="8dp" />
            <Button android:id="@+id/btnCleanData" android:layout_width="match_parent"
                android:layout_height="44dp" android:text="🗑️ 清除未上传数据"
                android:textAllCaps="false" android:textSize="14sp"
                android:backgroundTint="#dc2626" android:textColor="#fff"
                android:layout_marginBottom="8dp" app:cornerRadius="8dp" />
        </LinearLayout>

        <!-- Log Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#1e293b"
            android:padding="16dp" android:layout_marginBottom="12dp"
            android:elevation="2dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginBottom="12dp">
                <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                    android:layout_weight="1" android:text="📋 运行日志"
                    android:textSize="16sp" android:textStyle="bold"
                    android:textColor="#64748b" />
                <Button android:id="@+id/btnCopyLog" android:layout_width="wrap_content"
                    android:layout_height="32dp" android:text="复制"
                    android:textAllCaps="false" android:textSize="11sp"
                    android:backgroundTint="#475569" android:textColor="#94a3b8"
                    android:layout_marginEnd="8dp" app:cornerRadius="6dp" />
                <Button android:id="@+id/btnClearLog" android:layout_width="wrap_content"
                    android:layout_height="32dp" android:text="清空"
                    android:textAllCaps="false" android:textSize="11sp"
                    android:backgroundTint="#334155" android:textColor="#94a3b8"
                    app:cornerRadius="6dp" />
            </LinearLayout>
            <ScrollView android:id="@+id/logScrollView" android:layout_width="match_parent"
                android:layout_height="200dp"
                android:background="#0f172a" android:padding="8dp"
                android:fadingEdgeLength="8dp"
                android:requiresFadingEdge="vertical">
                <TextView android:id="@+id/diagLog" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="暂无日志"
                    android:textSize="11sp" android:textColor="#94a3b8"
                    android:typeface="monospace"
                    android:lineSpacingExtra="2dp" />
            </ScrollView>
        </LinearLayout>

    </LinearLayout>
</ScrollView>
