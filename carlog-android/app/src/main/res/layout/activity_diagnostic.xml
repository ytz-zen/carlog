<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="#f0f4f8">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="16dp">

        <!-- GPS Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📡 GPS 状态" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagGpsInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#475569" android:lineSpacingExtra="4dp" />
            <Button android:id="@+id/btnRefreshGps" android:layout_width="match_parent"
                android:layout_height="36dp" android:text="刷新 GPS"
                android:textAllCaps="false" android:textSize="12sp"
                android:backgroundTint="#e2e8f0" android:textColor="#475569"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Server Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🌐 服务器" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagServerInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#475569" android:lineSpacingExtra="4dp" />
            <Button android:id="@+id/btnTestConn" android:layout_width="match_parent"
                android:layout_height="36dp" android:text="测试连接"
                android:textAllCaps="false" android:textSize="12sp"
                android:backgroundTint="#4f46e5" android:textColor="#fff"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Local Data Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="💾 本地数据" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagLocalInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#475569" android:lineSpacingExtra="4dp" />
            <Button android:id="@+id/btnTestUpload" android:layout_width="match_parent"
                android:layout_height="36dp" android:text="测试上传"
                android:textAllCaps="false" android:textSize="12sp"
                android:backgroundTint="#059669" android:textColor="#fff"
                android:layout_marginTop="8dp" />
            <Button android:id="@+id/btnCleanData" android:layout_width="match_parent"
                android:layout_height="36dp" android:text="清除未上传数据"
                android:textAllCaps="false" android:textSize="12sp"
                android:backgroundTint="#dc2626" android:textColor="#fff"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- OBD Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🔌 OBD 车辆数据" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagObdInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="未连接"
                android:textSize="13sp" android:textColor="#475569" android:lineSpacingExtra="4dp" />
            <Button android:id="@+id/btnObdConnect" android:layout_width="match_parent"
                android:layout_height="36dp" android:text="连接 OBD"
                android:textAllCaps="false" android:textSize="12sp"
                android:backgroundTint="#4f46e5" android:textColor="#fff"
                android:layout_marginTop="8dp" />
        </LinearLayout>

        <!-- Config Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp" android:layout_marginBottom="12dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="⚙️ 当前配置" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <TextView android:id="@+id/diagConfigInfo" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="加载中..."
                android:textSize="13sp" android:textColor="#475569" android:lineSpacingExtra="4dp" />
        </LinearLayout>

        <!-- Log Section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:background="#ffffff"
            android:padding="16dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="📋 运行日志" android:textSize="16sp" android:textStyle="bold"
                android:textColor="#1e293b" android:layout_marginBottom="12dp" />
            <LinearLayout android:layout_width="match_parent"
                android:layout_height="240dp" android:orientation="vertical">
                <ScrollView android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#1e293b" android:padding="8dp"
                    android:fadingEdgeLength="8dp"
                    android:requiresFadingEdge="vertical">
                    <TextView android:id="@+id/diagLog" android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:text="暂无日志"
                        android:textSize="11sp" android:textColor="#94a3b8"
                        android:typeface="monospace"
                        android:lineSpacingExtra="2dp" />
                </ScrollView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
