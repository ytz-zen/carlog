<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/carlog_settings_title" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="车辆名称" android:textSize="14sp" android:layout_marginTop="8dp" />
        <EditText android:id="@+id/etCarName" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="如: 我的小黑" android:inputType="text" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="服务器地址" android:textSize="14sp" android:layout_marginTop="8dp" />
        <EditText android:id="@+id/etServerUrl" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="http://192.168.5.193:3012" android:inputType="textUri" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="API Key" android:textSize="14sp" android:layout_marginTop="16dp" />
        <EditText android:id="@+id/etApiKey" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="从服务器配置页面获取" android:inputType="textPassword" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="油箱容量(升)" android:textSize="14sp" android:layout_marginTop="16dp" />
        <EditText android:id="@+id/etTankCapacity" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="60" android:inputType="numberDecimal" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginTop="16dp" android:padding="12dp"
            android:background="#22FFFFFF">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="实时推送日志" android:textSize="14sp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="将运行日志发送到后台服务器，方便排查问题"
                    android:textSize="11sp" android:textColor="#AAAAAA" />
            </LinearLayout>
            <androidx.appcompat.widget.SwitchCompat android:id="@+id/switchPushLogs"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:checked="false" />
        </LinearLayout>

        <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="保存" android:layout_marginTop="24dp" android:padding="16dp" />
    </LinearLayout>
</ScrollView>
