<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent" android:padding="24dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="carlog_settings_title" android:textSize="24sp" android:textStyle="bold" android:layout_marginBottom="24dp" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="carlog_label_server" android:textSize="14sp" android:layout_marginTop="8dp" />
        <EditText android:id="@+id/etServerUrl" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="carlog_hint_server" android:inputType="textUri" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="carlog_label_apikey" android:textSize="14sp" android:layout_marginTop="16dp" />
        <EditText android:id="@+id/etApiKey" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="carlog_hint_apikey" android:inputType="textPassword" />

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="carlog_label_tank" android:textSize="14sp" android:layout_marginTop="16dp" />
        <EditText android:id="@+id/etTankCapacity" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:hint="carlog_hint_tank" android:inputType="numberDecimal" />

        <Button android:id="@+id/btnSave" android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="carlog_btn_save" android:layout_marginTop="24dp" android:padding="16dp" />
    </LinearLayout>
</ScrollView>
