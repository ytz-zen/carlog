<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0f172a"
    android:paddingTop="?attr/actionBarSize">

    <!-- 顶部状态栏 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#1e293b"
        android:padding="12dp"
        android:elevation="4dp">

        <TextView
            android:id="@+id/tvServerStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🟡 连接中..."
            android:textSize="13sp"
            android:textColor="#94a3b8" />

        <TextView
            android:id="@+id/tvGpsStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📡 GPS: --"
            android:textSize="13sp"
            android:textColor="#94a3b8"
            android:gravity="center" />

        <ImageButton
            android:id="@+id/btnRefresh"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="刷新"
            android:scaleType="center" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_manage"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="设置"
            android:scaleType="center"
            android:layout_marginStart="4dp" />

        <ImageButton
            android:id="@+id/btnDiagnostic"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_search"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="诊断"
            android:scaleType="center"
            android:layout_marginStart="4dp" />
    </LinearLayout>

    <!-- 第一行：行程状态 + GPS/OBD -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:padding="12dp"
        android:weightSum="2">

        <!-- 左侧：行程状态 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:background="#1e293b"
            android:padding="16dp"
            android:elevation="2dp"
            android:gravity="center">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚗 行程状态"
                android:textSize="16sp"
                android:textColor="#64748b"
                android:textStyle="bold"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTripMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="20sp"
                android:textColor="#fbbf24"
                android:textStyle="bold"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTripDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="36sp"
                android:textColor="#e2e8f0"
                android:textStyle="bold"
                android:fontFamily="monospace"
                android:layout_marginBottom="16dp" />

            <TextView
                android:id="@+id/tvTripPoints"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="--"
                android:textSize="14sp"
                android:textColor="#94a3b8"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <Button
                    android:id="@+id/btnStart"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="▶ 开始"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:backgroundTint="#4f46e5"
                    android:textColor="#fff"
                    android:layout_marginEnd="4dp"
                    app:cornerRadius="8dp" />

                <Button
                    android:id="@+id/btnStop"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_weight="1"
                    android:text="⏹ 结束"
                    android:textAllCaps="false"
                    android:textSize="14sp"
                    android:backgroundTint="#ef4444"
                    android:textColor="#fff"
                    android:layout_marginStart="4dp"
                    app:cornerRadius="8dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- 右侧：GPS + OBD -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:orientation="vertical"
            android:weightSum="2">

            <!-- GPS 信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:layout_marginBottom="8dp"
                android:orientation="vertical"
                android:background="#1e293b"
                android:padding="16dp"
                android:elevation="2dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📡 GPS 定位"
                    android:textSize="16sp"
                    android:textColor="#64748b"
                    android:textStyle="bold"
                    android:layout_marginBottom="12dp" />

                <TextView
                    android:id="@+id/tvGpsData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="13sp"
                    android:textColor="#cbd5e1"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>

            <!-- OBD 信息 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:orientation="vertical"
                android:background="#1e293b"
                android:padding="16dp"
                android:elevation="2dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="🔌 OBD 数据"
                        android:textSize="16sp"
                        android:textColor="#64748b"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnObdConnect"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:text="连接"
                        android:textAllCaps="false"
                        android:textSize="11sp"
                        android:backgroundTint="#0ea5e9"
                        android:textColor="#fff"
                        app:cornerRadius="6dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tvObdData"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="--"
                    android:textSize="13sp"
                    android:textColor="#cbd5e1"
                    android:fontFamily="monospace"
                    android:lineSpacingMultiplier="1.4" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <!-- 第二行：历史行程 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:orientation="vertical"
        android:background="#1e293b"
        android:padding="16dp"
        android:elevation="2dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="📋 历史行程"
            android:textSize="16sp"
            android:textColor="#64748b"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <ListView
            android:id="@+id/lvHistoryTrips"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="#334155"
            android:dividerHeight="1dp"
            android:background="#0f172a" />
    </LinearLayout>
</LinearLayout>
