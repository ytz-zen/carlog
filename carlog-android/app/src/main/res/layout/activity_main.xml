<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#f0f4f8"
    android:paddingTop="?attr/actionBarSize">

    <!-- Status Bar + Refresh -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#ffffff" android:paddingTop="12dp" android:paddingBottom="12dp"
        android:paddingLeft="16dp" android:paddingRight="16dp"
        app:elevation="2dp">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:orientation="vertical">
            <TextView android:id="@+id/tvServerStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="🟡 连接中..." android:textSize="12sp"
                android:textColor="#64748b" />
            <TextView android:id="@+id/tvGpsStatus" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="📡 GPS: --" android:textSize="11sp"
                android:textColor="#94a3b8" android:layout_marginTop="1dp" />
        </LinearLayout>
        <ImageButton android:id="@+id/btnRefresh"
            android:layout_width="36dp" android:layout_height="36dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="刷新" android:scaleType="center" />
    </LinearLayout>

    <!-- Main Card -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:layout_margin="16dp"
        android:background="#ffffff" android:paddingTop="24dp" android:paddingBottom="20dp"
        android:paddingLeft="20dp" android:paddingRight="20dp"
        app:elevation="2dp">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/carlog_app_name" android:textSize="28sp" android:textStyle="bold"
            android:textColor="#1e293b" android:layout_gravity="center" android:layout_marginBottom="2dp" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/carlog_subtitle" android:textSize="13sp" android:textColor="#94a3b8"
            android:layout_gravity="center" android:layout_marginBottom="20dp" />

        <TextView android:id="@+id/tvTripStatus" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="状态: 🟢 等待行驶..." android:textSize="14sp"
            android:textAlignment="center" android:textColor="#475569"
            android:background="#f8fafc" android:padding="12dp"
            android:layout_marginBottom="20dp" />

        <Button android:id="@+id/btnStart" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="@string/carlog_btn_start"
            android:textAllCaps="false" android:textSize="15sp"
            android:backgroundTint="#4f46e5" android:textColor="#fff"
            android:layout_marginBottom="8dp" app:cornerRadius="8dp" />
        <Button android:id="@+id/btnStop" android:layout_width="match_parent"
            android:layout_height="48dp" android:text="@string/carlog_btn_stop"
            android:textAllCaps="false" android:textSize="15sp"
            android:backgroundTint="#ef4444" android:textColor="#fff"
            android:layout_marginBottom="20dp" app:cornerRadius="8dp" />

        <TextView android:id="@+id/tvInfo" android:layout_width="match_parent"
            android:layout_height="wrap_content" android:text="行驶后自动记录GPS轨迹"
            android:textSize="12sp" android:textColor="#94a3b8"
            android:textAlignment="center" android:layout_marginBottom="16dp" />

        <Button android:id="@+id/btnSettings" android:layout_width="match_parent"
            android:layout_height="40dp" android:text="设置"
            android:textAllCaps="false" android:textSize="13sp"
            android:backgroundTint="#e2e8f0" android:textColor="#475569"
            android:layout_marginBottom="8dp"
            app:cornerRadius="8dp" />
        <Button android:id="@+id/btnDiagnostic" android:layout_width="match_parent"
            android:layout_height="40dp" android:text="🔍 诊断"
            android:textAllCaps="false" android:textSize="13sp"
            android:backgroundTint="#f1f5f9" android:textColor="#64748b"
            app:cornerRadius="8dp" />
    </LinearLayout>
</LinearLayout>
