<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">

    <!-- Status Bar -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:background="#f5f5f5" android:padding="8dp" android:layout_marginBottom="16dp">
        <TextView android:id="@+id/tvServerStatus" android:layout_width="0dp" android:layout_height="wrap_content"
            android:layout_weight="1" android:text="🟡 连接中..." android:textSize="12sp" />
        <TextView android:id="@+id/tvGpsStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📡 GPS: --" android:textSize="12sp" android:layout_marginStart="8dp" />
    </LinearLayout>

    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/carlog_app_name" android:textSize="36sp" android:textStyle="bold"
        android:layout_gravity="center" android:layout_marginBottom="4dp" />
    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/carlog_subtitle" android:textSize="14sp" android:textColor="#666"
        android:layout_gravity="center" android:layout_marginBottom="24dp" />

    <!-- Trip Status -->
    <TextView android:id="@+id/tvTripStatus" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="状态: 等待行驶..." android:textSize="14sp" android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Buttons -->
    <Button android:id="@+id/btnStart" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/carlog_btn_start" android:backgroundTint="#4CAF50" android:textColor="#fff"
        android:padding="16dp" android:layout_marginBottom="8dp" />
    <Button android:id="@+id/btnStop" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="@string/carlog_btn_stop" android:backgroundTint="#f44336" android:textColor="#fff"
        android:padding="16dp" android:layout_marginBottom="16dp" />

    <!-- Info -->
    <TextView android:id="@+id/tvInfo" android:layout_width="match_parent" android:layout_height="wrap_content"
        android:text="本次行程: --" android:textSize="12sp" android:textColor="#888"
        android:layout_marginBottom="24dp" />

    <Button android:id="@+id/btnSettings" android:layout_width="wrap_content" android:layout_height="wrap_content"
        android:text="@string/carlog_btn_settings" android:layout_gravity="center" />
</LinearLayout>
